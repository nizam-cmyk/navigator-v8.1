  "rules": {
    "good_status": {
      "label": "Good Status",
      "cgpa_min": 2.0,
      "condition": "CGPA 2.00 and above",
      "meaning": "Student is in good academic standing."
    },
    "probation_1": {
      "label": "Academic Probation 1",
      "cgpa_below": 2.0,
      "consecutive_semesters": 1,
      "condition": "CGPA below 2.00 for any semester",
      "meaning": "Student may be placed on Academic Probation 1."
    },
    "probation_2": {
      "label": "Academic Probation 2",
      "cgpa_below": 2.0,
      "consecutive_semesters": 2,
      "condition": "CGPA below 2.00 for two consecutive semesters",
      "meaning": "Student may be placed on Academic Probation 2."
    },
    "dismissal": {
      "label": "Academic Dismissal",
      "cgpa_below": 2.0,
      "consecutive_semesters": 3,
      "condition": "CGPA below 2.00 for three consecutive semesters",
      "meaning": "Student may be dismissed."
    }
  },
  "calculation_notes": {
    "gpa_formula": "GPA = total point average / total credit",
    "cgpa_formula": "CGPA = sum of semester point averages / sum of semester total credits"
  },
  "safety_notes": [
    "Do not declare dismissal from CGPA alone unless the consecutive semester pattern is known.",
    "Final academic status must follow official University/Faculty records."
  ],
  "handbook_reference": "Grading Systems and Academic Standing"
